{
  "manifest_version": 3,
  "name": "AI Chat TOC",
  "version": "1.9",
  "description": "Adds a right-side table of contents navigation to AI chat pages like ChatGPT, Gemini and Claude / 为 ChatGPT、Gemini、Claude 等 AI 对话页面添加右侧目录导航",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.com/*",
        "https://claude.ai/*"
      ],
      "js": ["html2canvas.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
